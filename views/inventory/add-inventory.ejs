<div id="message-container">
  <% if (messages && messages.notice && messages.notice.length > 0) { %>
    <% messages.notice.forEach(msg => { %>
      <div class="alert alert-success">
        <span class="alert-close" onclick="this.parentElement.style.display='none';">&times;</span>
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  <% if (messages && messages.error && messages.error.length > 0) { %>
    <% messages.error.forEach(msg => { %>
      <div class="alert alert-error">
        <span class="alert-close" onclick="this.parentElement.style.display='none';">&times;</span>
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-error">
      <h3>The following errors were detected:</h3>
      <ul>
        <% errors.forEach(error => { %>
          <li><%= typeof error === 'object' ? error.msg : error %></li>
        <% }); %>
      </ul>
    </div>
  <% } %>
</div>

<h1>Add New Vehicle</h1>
<p class="subtitle">Add a new vehicle to the inventory system</p>

<form method="POST" action="/inv/add-inventory" id="addVehicleForm" class="form add-form">
  <fieldset>
    <legend>Vehicle Information</legend>

    <!-- Classification -->
    <div class="form-group">
      <label for="classificationList">Classification <span class="required">*</span></label>
      <%- classificationSelect %>
    </div>

    <!-- Make -->
    <div class="form-group">
      <label for="invMake">Make <span class="required">*</span></label>
      <input
        type="text"
        id="invMake"
        name="inv_make"
        class="form-control"
        value="<%= typeof inv_make !== 'undefined' ? inv_make : '' %>"
        required
        minlength="3"
        maxlength="50"
        placeholder="e.g., Toyota, Ford, BMW"
        title="Enter the vehicle make (minimum 3 characters)"
      />
    </div>

    <!-- Model -->
    <div class="form-group">
      <label for="invModel">Model <span class="required">*</span></label>
      <input
        type="text"
        id="invModel"
        name="inv_model"
        class="form-control"
        value="<%= typeof inv_model !== 'undefined' ? inv_model : '' %>"
        required
        minlength="3"
        maxlength="50"
        placeholder="e.g., Camry, Mustang, 3 Series"
        title="Enter the vehicle model (minimum 3 characters)"
      />
    </div>

    <!-- Year -->
    <div class="form-group">
      <label for="invYear">Year <span class="required">*</span></label>
      <input
        type="number"
        id="invYear"
        name="inv_year"
        class="form-control"
        value="<%= typeof inv_year !== 'undefined' ? inv_year : '' %>"
        required
        min="1900"
        max="<%= new Date().getFullYear() + 1 %>"
        placeholder="e.g., 2024"
        title="Enter a valid year between 1900 and current year"
      />
    </div>

    <!-- Description -->
    <div class="form-group">
      <label for="invDescription">Description <span class="required">*</span></label>
      <textarea
        id="invDescription"
        name="inv_description"
        class="form-control"
        required
        minlength="10"
        maxlength="500"
        rows="4"
        placeholder="Enter a detailed description of the vehicle..."
        title="Enter vehicle description (minimum 10 characters)"
      ><%= typeof inv_description !== 'undefined' ? inv_description : '' %></textarea>
      <small>Maximum 500 characters</small>
    </div>

    <!-- Price -->
    <div class="form-group">
      <label for="invPrice">Price <span class="required">*</span></label>
      <input
        type="number"
        id="invPrice"
        name="inv_price"
        class="form-control"
        value="<%= typeof inv_price !== 'undefined' ? inv_price : '' %>"
        required
        min="0"
        step="0.01"
        placeholder="0.00"
        title="Enter the vehicle price"
      />
    </div>

    <!-- Mileage -->
    <div class="form-group">
      <label for="invMiles">Mileage (km) <span class="required">*</span></label>
      <input
        type="number"
        id="invMiles"
        name="inv_miles"
        class="form-control"
        value="<%= typeof inv_miles !== 'undefined' ? inv_miles : '' %>"
        required
        min="0"
        placeholder="0"
        title="Enter current vehicle mileage"
      />
    </div>

    <!-- Color -->
    <div class="form-group">
      <label for="invColor">Color <span class="required">*</span></label>
      <input
        type="text"
        id="invColor"
        name="inv_color"
        class="form-control"
        value="<%= typeof inv_color !== 'undefined' ? inv_color : '' %>"
        required
        maxlength="20"
        placeholder="e.g., Red, Blue, Silver"
        title="Enter the vehicle color"
      />
    </div>

    <!-- Image Path -->
    <div class="form-group">
      <label for="invImage">Image Path <span class="required">*</span></label>
      <input
        type="text"
        id="invImage"
        name="inv_image"
        class="form-control"
        value="<%= typeof inv_image !== 'undefined' ? inv_image : '/images/vehicles/no-image.png' %>"
        required
        placeholder="/images/vehicles/no-image.png"
        title="Enter the full image path"
      />
      <small>Use /images/vehicles/no-image.png if image not available</small>
    </div>

    <!-- Thumbnail Path -->
    <div class="form-group">
      <label for="invThumbnail">Thumbnail Path <span class="required">*</span></label>
      <input
        type="text"
        id="invThumbnail"
        name="inv_thumbnail"
        class="form-control"
        value="<%= typeof inv_thumbnail !== 'undefined' ? inv_thumbnail : '/images/vehicles/no-image-tn.png' %>"
        required
        placeholder="/images/vehicles/no-image-tn.png"
        title="Enter the thumbnail image path"
      />
      <small>Use /images/vehicles/no-image-tn.png if thumbnail not available</small>
    </div>

    <!-- Form Actions -->
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Add Vehicle</button>
      <a href="/inv/" class="btn btn-secondary">Cancel</a>
    </div>
  </fieldset>
</form>
