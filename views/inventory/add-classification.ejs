<div id="message-container">
  <% if (errors) { %>
    <div class="error-container">
      <h3>The following errors were detected:</h3>
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error %></li>
        <% }); %>
      </ul>
    </div>
  <% } %>
</div>

<h1><%= title %></h1>

<form method="POST" action="/inv/add-classification" class="form">
  <fieldset>
    <legend><%= title %></legend>

    <label for="classificationName">Classification Name:</label>
    <input
      type="text"
      id="classificationName"
      name="classification_name"
      value="<%= typeof classification_name !== 'undefined' ? classification_name : '' %>"
      required
      pattern="[a-zA-Z0-9]+"
      maxlength="50"
      title="Classification name cannot contain spaces or special characters"
    />
    <p class="form-note">Note: Classification name cannot contain spaces or special characters.</p>

    <button type="submit" class="btn">Add Classification</button>
  </fieldset>
</form>
