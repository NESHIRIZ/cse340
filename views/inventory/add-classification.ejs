<div id="message-container">
  <% if (messages && messages.notice && messages.notice.length > 0) { %>
    <% messages.notice.forEach(msg => { %>
      <div class="alert alert-success">
        <span class="alert-close" onclick="this.parentElement.style.display='none';">&times;</span>
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  <% if (messages && messages.error && messages.error.length > 0) { %>
    <% messages.error.forEach(msg => { %>
      <div class="alert alert-error">
        <span class="alert-close" onclick="this.parentElement.style.display='none';">&times;</span>
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-error">
      <h3>The following errors were detected:</h3>
      <ul>
        <% errors.forEach(error => { %>
          <li><%= typeof error === 'object' ? error.msg : error %></li>
        <% }); %>
      </ul>
    </div>
  <% } %>
</div>

<h1>Add New Classification</h1>
<p class="subtitle">Add a new vehicle classification to the system</p>

<form method="POST" action="/inv/add-classification" class="form add-form">
  <fieldset>
    <legend>Classification Information</legend>

    <div class="form-group">
      <label for="classificationName">Classification Name <span class="required">*</span></label>
      <input
        type="text"
        id="classificationName"
        name="classification_name"
        class="form-control"
        value="<%= typeof classification_name !== 'undefined' ? classification_name : '' %>"
        required
        pattern="[a-zA-Z0-9]+"
        maxlength="50"
        title="Classification name cannot contain spaces or special characters"
        placeholder="Enter classification name (e.g., 'Sedan', 'SUV')"
      />
      <small class="form-note">Note: Classification name cannot contain spaces or special characters. Use letters and numbers only.</small>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Add Classification</button>
      <a href="/inv/" class="btn btn-secondary">Cancel</a>
    </div>
  </fieldset>
</form>
