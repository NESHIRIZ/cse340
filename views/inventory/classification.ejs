<h1><%= title %></h1>

<div class="rating-filter">
  <form method="GET" action="" class="review-filter-form">
    <label for="minRating">Minimum Rating:</label>
    <select id="minRating" name="minRating" onchange="this.form.submit()">
      <option value="0" <%= minRating == 0 ? 'selected':'' %>>All</option>
      <option value="3" <%= minRating == 3 ? 'selected':'' %>>3+ Stars</option>
      <option value="4" <%= minRating == 4 ? 'selected':'' %>>4+ Stars</option>
      <option value="4.5" <%= minRating == 4.5 ? 'selected':'' %>>4.5+ Stars</option>
    </select>
  </form>
</div>

<% if (vehicles && vehicles.length > 0) { %>
  <div class="vehicles-grid">
    <% vehicles.forEach((vehicle) => { %>
      <div class="vehicle-card">
        <a href="/vehicles/<%= vehicle.inventory_id %>">
          <img src="<%= vehicle.inv_thumbnail %>" alt="<%= vehicle.inv_make %> <%= vehicle.inv_model %>" class="vehicle-thumbnail">
          <h3><%= vehicle.inv_make %> <%= vehicle.inv_model %></h3>
          <p class="vehicle-year"><%= vehicle.inv_year %></p>
          <p class="vehicle-price">$<%= Number(vehicle.inv_price).toLocaleString() %></p>          <p class="vehicle-rating">Rating: <strong><%= Number(vehicle.avg_rating).toFixed(1) %></strong> / 5</p>
          <p class="vehicle-review-count"><%= vehicle.review_count %> review<%= vehicle.review_count === 1 ? '' : 's' %></p>        </a>
      </div>
    <% }); %>
  </div>
<% } else { %>
  <p>No vehicles available in this classification.</p>
<% } %>
