
<body>

    <!-- Hero Section -->
    <section class="hero">
        <img class="hero-image" src="/images/vehicles/delorean.jpg" alt="CSE Motors Hero Car">
        <div class="hero-text">
            <h1>Welcome to CSE Motors</h1>

            <div class="featured-car">
                <h2>DMC DeLorean</h2>
                <ul>
                    <li>Three Cup Holders</li>
                    <li>Superman Doors</li>
                    <li>Fuzzy Dice</li>
                </ul>
                <a href="/contact" class="btn-primary">Order Today</a>
            </div>
        </div>
    </section>

    <!-- Vehicle Classifications Section -->
    <section class="vehicle-classifications">
        <h2>Explore Our Inventory</h2>
        <%- classificationGrid %>
    </section>

    <!-- Top Rated Vehicles Section -->
    <section class="top-rated-vehicles">
      <h2>Top Rated Vehicles</h2>
      <% if (topVehicles && topVehicles.length > 0) { %>
        <div class="top-rated-grid">
          <% topVehicles.forEach((vehicle) => { %>
            <article class="top-rated-card">
              <a href="/vehicles/<%= vehicle.inventory_id %>">
                <img src="<%= vehicle.inv_thumbnail %>" alt="<%= vehicle.inv_make %> <%= vehicle.inv_model %>" />
                <div class="card-content">
                  <h3><%= vehicle.inv_make %> <%= vehicle.inv_model %></h3>
                  <p>$<%= Number(vehicle.inv_price).toLocaleString() %></p>
                  <p>Rating: <strong><%= vehicle.avg_rating %></strong> / 5</p>
                  <p><%= vehicle.review_count %> reviews</p>
                </div>
              </a>
            </article>
          <% }); %>
        </div>
      <% } else { %>
        <p>No rated vehicles yet. Be the first to review one!</p>
      <% } %>
    </section>

    <!-- Grid Section -->
    <section class="grid-section">
        <!-- Left: Upgrades -->
        <div class="grid-left">
            <h2>DeLorean Upgrades</h2>
            <div class="upgrade-cards">
                <div class="card">
                    <img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor">
                    <p>Flux Capacitor</p>
                </div>
                <div class="card">
                    <img src="/images/upgrades/flame.jpg" alt="Flame Decals">
                    <p>Flame Decals</p>
                </div>
                <div class="card">
                    <img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper Stickers">
                    <p>Bumper Stickers</p>
                </div>
                <div class="card">
                    <img src="/images/upgrades/hub-cap.jpg" alt="Hubcaps">
                    <p>Hubcaps</p>
                </div>
            </div>
        </div>

        <!-- Right: Reviews -->
        <div class="grid-right">
            <h2>DMC DeLorean Reviews</h2>
            <ul class="reviews">
                <li>So fast, it's like traveling in time - 4/5</li>
                <li>Coolest ride on the road - 4/5</li>
                <li>I'm feeling McFly - 5/5</li>
                <li>The most futuristic ride of our day - 4.5/5</li>
                <li>80s Living and Lavish - 5/5</li>
            </ul>
        </div>
    </section>

</body>
