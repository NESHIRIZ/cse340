<div id="message-container">
  <% if (messages && messages.notice && messages.notice.length > 0) { %>
    <% messages.notice.forEach(msg => { %>
      <div class="alert alert-success">
        <span class="alert-close" onclick="this.parentElement.style.display='none';">&times;</span>
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  <% if (messages && messages.error && messages.error.length > 0) { %>
    <% messages.error.forEach(msg => { %>
      <div class="alert alert-error">
        <span class="alert-close" onclick="this.parentElement.style.display='none';">&times;</span>
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-error">
      <h3>The following errors were detected:</h3>
      <ul>
        <% errors.forEach(error => { %>
          <li><%= typeof error === 'object' ? error.msg : error %></li>
        <% }); %>
      </ul>
    </div>
  <% } %>
</div>

<h1>Create Account</h1>
<p class="subtitle">Register for a new account</p>

<form method="POST" action="/account/register" class="form auth-form">
  <fieldset>
    <legend>Registration Information</legend>

    <div class="form-group">
      <label for="first_name">First Name <span class="required">*</span></label>
      <input
        type="text"
        id="first_name"
        name="first_name"
        class="form-control"
        value="<%= typeof first_name !== 'undefined' ? first_name : '' %>"
        required
        placeholder="John"
      />
    </div>

    <div class="form-group">
      <label for="last_name">Last Name <span class="required">*</span></label>
      <input
        type="text"
        id="last_name"
        name="last_name"
        class="form-control"
        value="<%= typeof last_name !== 'undefined' ? last_name : '' %>"
        required
        minlength="2"
        placeholder="Doe"
      />
    </div>

    <div class="form-group">
      <label for="email">Email <span class="required">*</span></label>
      <input
        type="email"
        id="email"
        name="email"
        class="form-control"
        value="<%= typeof email !== 'undefined' ? email : '' %>"
        required
        placeholder="your@email.com"
      />
    </div>

    <div class="form-group">
      <label for="password">Password <span class="required">*</span></label>
      <input
        type="password"
        id="password"
        name="password"
        class="form-control"
        required
        minlength="8"
        placeholder="Enter a strong password"
      />
      <small class="form-note">
        Password must be at least 8 characters and contain uppercase, lowercase, and numbers.
      </small>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Create Account</button>
      <a href="/" class="btn btn-secondary">Cancel</a>
    </div>

    <p class="form-footer">
      Already have an account? <a href="/account/login">Sign in here</a>
    </p>
  </fieldset>
</form>

<style>
  .auth-form {
    max-width: 500px;
  }

  .form-footer {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.95rem;
  }

  .form-footer a {
    color: #ff6600;
    text-decoration: none;
    font-weight: 600;
  }

  .form-footer a:hover {
    text-decoration: underline;
  }
</style>
