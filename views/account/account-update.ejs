<div id="message-container">
  <% if (message) { %>
    <div class="alert alert-success">
      <span class="alert-close" onclick="this.parentElement.style.display='none';">&times;</span>
      <%= message %>
    </div>
  <% } %>
  <% if (messages && messages.notice && messages.notice.length > 0) { %>
    <% messages.notice.forEach(msg => { %>
      <div class="alert alert-success">
        <span class="alert-close" onclick="this.parentElement.style.display='none';">&times;</span>
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  <% if (messages && messages.error && messages.error.length > 0) { %>
    <% messages.error.forEach(msg => { %>
      <div class="alert alert-error">
        <span class="alert-close" onclick="this.parentElement.style.display='none';">&times;</span>
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-error">
      <h3>The following errors were detected:</h3>
      <ul>
        <% errors.forEach(error => { %>
          <li><%= typeof error === 'object' ? error.msg : error %></li>
        <% }); %>
      </ul>
    </div>
  <% } %>
</div>

<h1>Account Update</h1>
<p class="subtitle">Manage your account information and password</p>

<!-- Account Update Form -->
<form method="POST" action="/account/update" class="form add-form account-form">
  <fieldset>
    <legend>Update Account Information</legend>

    <div class="form-group">
      <label for="firstName">First Name <span class="required">*</span></label>
      <input
        type="text"
        id="firstName"
        name="first_name"
        class="form-control"
        value="<%= typeof account.first_name !== 'undefined' ? account.first_name : '' %>"
        required
        minlength="1"
        maxlength="50"
        placeholder="Your first name"
      />
    </div>

    <div class="form-group">
      <label for="lastName">Last Name <span class="required">*</span></label>
      <input
        type="text"
        id="lastName"
        name="last_name"
        class="form-control"
        value="<%= typeof account.last_name !== 'undefined' ? account.last_name : '' %>"
        required
        minlength="2"
        maxlength="50"
        placeholder="Your last name"
      />
    </div>

    <div class="form-group">
      <label for="email">Email <span class="required">*</span></label>
      <input
        type="email"
        id="email"
        name="email"
        class="form-control"
        value="<%= typeof account.email !== 'undefined' ? account.email : '' %>"
        required
        placeholder="your@email.com"
      />
    </div>

    <input type="hidden" name="account_id" value="<%= account.account_id %>" />

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Update Account</button>
      <a href="/account" class="btn btn-secondary">Cancel</a>
    </div>
  </fieldset>
</form>

<!-- Change Password Form -->
<form method="POST" action="/account/password" class="form add-form password-form">
  <fieldset>
    <legend>Change Password</legend>

    <div class="form-group">
      <label for="password">New Password <span class="required">*</span></label>
      <input
        type="password"
        id="password"
        name="password"
        class="form-control"
        required
        minlength="8"
        placeholder="Enter a strong password"
      />
      <small class="form-note">
        <strong>Password requirements:</strong><br>
        • At least 8 characters long<br>
        • At least 1 uppercase letter (A-Z)<br>
        • At least 1 lowercase letter (a-z)<br>
        • At least 1 number (0-9)
      </small>
    </div>

    <input type="hidden" name="account_id" value="<%= account.account_id %>" />

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Change Password</button>
      <a href="/account" class="btn btn-secondary">Cancel</a>
    </div>
  </fieldset>
</form>
    }
  });

  // Client-side validation for password form
  document.querySelector('form[action="/account/password"]').addEventListener('submit', function(e) {
    const errors = [];
    const password = document.getElementById('password').value;

    if (!password) errors.push("Password is required.");
    if (password && password.length < 12) errors.push("Password must be at least 12 characters long.");
    if (password && !/[A-Z]/.test(password)) errors.push("Password must contain at least 1 uppercase letter.");
    if (password && !/[0-9]/.test(password)) errors.push("Password must contain at least 1 number.");
    if (password && !/[!@#$%^&*]/.test(password)) errors.push("Password must contain at least 1 special character (!@#$%^&*).");

    if (errors.length > 0) {
      e.preventDefault();
      alert(errors.join('\n'));
    }
  });
</script>
